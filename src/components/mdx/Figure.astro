---
/**
 * 博客图片 + 图注（caption）。支持本地与远程图片、宽幅出血。
 * 用法（MDX）：<Figure src="/blog/x.png" alt="..." caption="图 1 · 说明文字" />
 */
interface Props {
  src: string;
  alt?: string;
  caption?: string;
  wide?: boolean;
  credit?: string;
}
const { src, alt = "", caption, wide = false, credit } = Astro.props;
---

<figure class={`not-prose my-9 ${wide ? "md:-mx-16 lg:-mx-24" : ""}`}>
  <img
    src={src}
    alt={alt}
    loading="lazy"
    decoding="async"
    class="w-full rounded-2xl border border-[color-mix(in_oklab,var(--color-ink)_10%,transparent)] bg-[var(--color-paper-2)]"
  />
  {(caption || credit) && (
    <figcaption class="mt-3 flex flex-wrap items-baseline gap-x-3 gap-y-1 px-1 text-[0.82rem] leading-relaxed text-[var(--color-stone)]">
      {caption && (
        <span>
          <span class="font-[var(--font-mono)] text-[var(--color-pine)]">▸ </span>{caption}
        </span>
      )}
      {credit && <span class="font-[var(--font-mono)] text-[0.72rem] text-[var(--color-stone-2)]">{credit}</span>}
    </figcaption>
  )}
</figure>
