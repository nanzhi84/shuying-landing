---
/**
 * 博客视频 + 图注（caption）。兼容流媒体：src 可为远程 mp4/webm 或 HLS。
 * 用法（MDX）：
 *   <Video src="https://cdn/x.mp4" poster="/blog/x.jpg" caption="视频 1 · 端到端成片" />
 */
interface Props {
  src: string;
  poster?: string;
  caption?: string;
  credit?: string;
  ratio?: string; // 如 "16 / 9" | "9 / 16"
  autoplay?: boolean;
  loop?: boolean;
  muted?: boolean;
  wide?: boolean;
}
const {
  src,
  poster,
  caption,
  credit,
  ratio = "16 / 9",
  autoplay = false,
  loop = false,
  muted = false,
  wide = false,
} = Astro.props;
import { mediaSrc } from "@/lib/url";
const isHls = src.endsWith(".m3u8");
const rSrc = mediaSrc(src);
const rPoster = poster ? mediaSrc(poster) : undefined;
---

<figure class={`not-prose my-9 ${wide ? "md:-mx-16 lg:-mx-24" : ""}`}>
  <div
    class="overflow-hidden rounded-2xl border border-[color-mix(in_oklab,var(--color-paper)_12%,transparent)] bg-[var(--color-ink)]"
    style={`aspect-ratio:${ratio}`}
  >
    <video
      class="h-full w-full object-contain"
      controls
      preload="metadata"
      playsinline
      poster={rPoster}
      autoplay={autoplay || undefined}
      loop={loop || undefined}
      muted={muted || autoplay || undefined}
      data-hls={isHls ? rSrc : undefined}
    >
      {!isHls && <source src={rSrc} />}
      您的浏览器不支持 HTML5 视频。
    </video>
  </div>
  {(caption || credit) && (
    <figcaption class="mt-3 flex flex-wrap items-baseline gap-x-3 gap-y-1 px-1 text-[0.82rem] leading-relaxed text-[var(--color-stone)]">
      {caption && (
        <span>
          <span class="font-[var(--font-mono)] text-[var(--color-pine)]">▶ </span>{caption}
        </span>
      )}
      {credit && <span class="font-[var(--font-mono)] text-[0.72rem] text-[var(--color-stone-2)]">{credit}</span>}
    </figcaption>
  )}
</figure>

{isHls && (
  <script>
    // 远程 HLS 流（.m3u8）的渐进增强：原生不支持时动态加载 hls.js
    const vids = document.querySelectorAll<HTMLVideoElement>("video[data-hls]");
    vids.forEach((v) => {
      const url = v.dataset.hls!;
      if (v.canPlayType("application/vnd.apple.mpegurl")) {
        v.src = url;
      } else {
        const s = document.createElement("script");
        s.src = "https://cdn.jsdelivr.net/npm/hls.js@1";
        s.onload = () => {
          // @ts-ignore
          const Hls = window.Hls;
          if (Hls?.isSupported()) {
            const hls = new Hls();
            hls.loadSource(url);
            hls.attachMedia(v);
          }
        };
        document.head.appendChild(s);
      }
    });
  </script>
)}
