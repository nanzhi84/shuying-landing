---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  tone?: "ink" | "paper";
  align?: "left" | "center";
  class?: string;
}
const { eyebrow, title, lead, tone = "ink", align = "left", class: cls = "" } = Astro.props;
const titleColor = tone === "paper" ? "text-[var(--color-paper)]" : "text-[var(--color-paper)]";
const leadColor = tone === "paper" ? "text-[var(--color-mist)]" : "text-[var(--color-stone)]";
---

<div class:list={[cls, align === "center" && "mx-auto max-w-2xl text-center"]}>
  {eyebrow && <p class:list={["eyebrow mb-4", tone === "paper" && "eyebrow--onink"]}>{eyebrow}</p>}
  <h2 class:list={["text-display-sm font-semibold", titleColor]}>{title}</h2>
  {lead && <p class:list={["mt-5 text-[1.05rem] leading-relaxed", leadColor]}>{lead}</p>}
</div>
